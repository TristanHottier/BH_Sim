# ═══════════════════════════════════════════════════════════════════════════════
#  BH_Sim — ignore list for Docker and Git
# ═══════════════════════════════════════════════════════════════════════════════

# ── Git / IDE ────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Temp ─────────────────────────────────────────────────────────────────────
*.tmp
*.temp

# ── Docker ───────────────────────────────────────────────────────────────────
# (Dockerfile COPY . — these should not be copied into the image)
.git/
.opencode/
