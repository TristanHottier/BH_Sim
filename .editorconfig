root_indent_size = 4
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
tab_width = 4
quote_style = single

[*.{js,json,yml,yaml,md,css,html}]
indent_size = 4
end_of_line = crlf

[*.{glsl,png,svg,ico}]
indent_size = 4
end_of_line = crlf

[package.json]
indent_size = 4
